{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "improvement-policy.schema.json",
  "title": "ImprovementPolicy",
  "description": "Constrains how passing-skill candidates and corrective patches may change a skill.",
  "type": "object",
  "required": ["approved_optimization_metrics", "required_preserved_thresholds", "candidate_pr_rule"],
  "properties": {
    "approved_optimization_metrics": {"type": "array", "items": {"type": "string"}},
    "required_preserved_thresholds": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "candidate_pr_rule": {"type": "string"},
    "max_version_bump": {"type": "integer", "minimum": 1},
    "measured_improvement": {"type": "object"},
    "allow_corrective_patch": {"type": "boolean"}
  }
}
