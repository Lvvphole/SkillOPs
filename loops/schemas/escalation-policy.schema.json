{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "escalation-policy.schema.json",
  "title": "EscalationPolicy",
  "description": "Declares when the loop must stop and request human input.",
  "type": "object",
  "required": ["max_escalations", "conditions"],
  "properties": {
    "max_escalations": {"type": "integer", "minimum": 0},
    "repair_limit": {"type": "integer", "minimum": 1},
    "conditions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "on_escalation": {"type": "string"}
  }
}
