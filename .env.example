# SkillOps environment (no secrets committed; copy to .env and fill locally).

# --- Python core runtime ---
SKILLOPS_DATA_DIR=./.skillops-data      # JSON run store (gitignored)
SKILLOPS_LOG_LEVEL=info                  # debug | info | warn | error

# --- Optional LLM provider (recommendations only; never decides pass/fail) ---
# The deterministic core does not call an LLM. These are placeholders for an
# adapter that generates patch/candidate suggestions, which are still verified.
ANTHROPIC_API_KEY=
SKILLOPS_LLM_MODEL=claude-opus-4-8

# --- Optional GitHub PR automation (operator-provided; not used in tests) ---
GITHUB_TOKEN=
GITHUB_REPOSITORY=Lvvphole/SkillOPs

# --- Existing TypeScript adapter layer (preserved) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
